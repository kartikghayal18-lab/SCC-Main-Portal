<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= branding?.brandName || 'Demo Coaching' %> - Admin Forgot Password</title>
  <link rel="icon" href="<%= branding?.faviconUrl || '/public/scc-icon.svg' %>" />
  <link rel="stylesheet" href="/public/styles.css" />
</head>
<body style="<%= branding?.cssVars || '' %>">
  <div class="container small">
    <div class="card login-hero">
      <p class="eyebrow">Admin Recovery</p>
      <h1>Forgot Password</h1>
      <p class="muted">Verify your class name, admin name, contact number, and email. After verification, an OTP will be sent to your email before you can create a new password.</p>
    </div>

    <% if (flash) { %>
      <div class="alert <%= flash.type %>"><%= flash.text %></div>
    <% } %>

    <form method="post" action="/admin/forgot-password" class="card">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>Class Name</label>
      <input type="text" name="className" required />

      <label>Admin Name</label>
      <input type="text" name="adminName" required />

      <label>Contact Number</label>
      <input type="text" name="contactPhone" required />

      <label>Email Address</label>
      <input type="email" name="email" required />

      <label>Security Check: <%= captcha.prompt %> = ?</label>
      <input type="text" name="captchaAnswer" inputmode="numeric" placeholder="Enter answer" required />

      <button type="submit" class="btn">Verify Details</button>
      <a href="/login" class="mini-link">Back to Login</a>
    </form>
  </div>
<script src="/public/super-admin-shortcut.js" data-user-role="<%= user?.role || '' %>"></script>
</body>
</html>
