<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= branding?.brandName || 'Demo Coaching' %> - Owner Reset Password</title>
  <link rel="icon" href="<%= branding?.faviconUrl || '/public/scc-icon.svg' %>" />
  <link rel="stylesheet" href="/public/styles.css" />
</head>
<body style="<%= branding?.cssVars || '' %>">
  <div class="container small">
    <div class="card login-hero">
      <p class="eyebrow">Owner Recovery</p>
      <h1>Reset Owner Password</h1>
      <p class="muted">Request an OTP on <strong><%= resetRequest?.email || 'your email' %></strong>, then set your new password.</p>
    </div>

    <% if (flash) { %>
      <div class="alert <%= flash.type %>"><%= flash.text %></div>
    <% } %>

    <div class="grid two">
      <div class="card">
        <h2>Request OTP</h2>
        <form method="post" action="/owner/reset-password/send-otp">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label>Security Check: <%= captcha.prompt %> = ?</label>
          <input type="text" name="captchaAnswer" inputmode="numeric" placeholder="Enter answer" required />
          <button type="submit" class="btn" <%= otpChannels?.email?.available ? '' : 'disabled' %>>
            Send OTP to Email
          </button>
          <p class="tiny-note">
            <%= otpChannels?.email?.available ? (otpChannels.email.masked || 'Email available') : (otpChannels?.email?.reason || 'Email not available') %>
          </p>
        </form>

        <% if (otpState) { %>
          <div class="alert <%= otpState.expired ? 'error' : 'warning' %>">
            <% if (otpState.expired) { %>
              Last OTP expired. Request a new one.
            <% } else { %>
              OTP sent to <strong><%= otpState.destinationMasked %></strong>. It expires in <strong><%= otpState.remainingSeconds %>s</strong>.
            <% } %>
          </div>
        <% } %>
      </div>

      <form method="post" action="/owner/reset-password" class="card">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <h2>Verify OTP & Set Password</h2>

        <label>OTP</label>
        <input type="text" name="otp" inputmode="numeric" maxlength="6" placeholder="6 digit OTP" required />

        <label>Security Check: <%= captcha.prompt %> = ?</label>
        <input type="text" name="captchaAnswer" inputmode="numeric" placeholder="Enter answer" required />

        <label>New Password</label>
        <input type="password" name="newPassword" minlength="8" required />

        <label>Confirm New Password</label>
        <input type="password" name="confirmPassword" minlength="8" required />

        <button type="submit" class="btn">Verify OTP and Reset Password</button>
        <a href="/owner/login" class="mini-link">Back to owner login</a>
      </form>
    </div>
  </div>
<script src="/public/super-admin-shortcut.js" data-user-role="<%= user?.role || '' %>"></script>
</body>
</html>
