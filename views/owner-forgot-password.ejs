<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= branding?.brandName || 'Demo Coaching' %> - Owner Forgot Password</title>
  <link rel="icon" href="<%= branding?.faviconUrl || '/public/scc-icon.svg' %>" />
  <link rel="stylesheet" href="/public/styles.css" />
</head>
<body style="<%= branding?.cssVars || '' %>">
  <div class="container small">
    <div class="card login-hero">
      <p class="eyebrow">Owner Recovery</p>
      <h1>Forgot Owner Password</h1>
      <p class="muted">Verify your owner username and recovery email. We will send an OTP by SMTP email before allowing a password reset.</p>
    </div>

    <% if (flash) { %>
      <div class="alert <%= flash.type %>"><%= flash.text %></div>
    <% } %>

    <form method="post" action="/owner/forgot-password" class="card">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <label>Owner Username</label>
      <input type="text" name="username" required />

      <label>Recovery Email</label>
      <input type="email" name="email" required />

      <label>Security Check: <%= captcha.prompt %> = ?</label>
      <input type="text" name="captchaAnswer" inputmode="numeric" placeholder="Enter answer" required />

      <button type="submit" class="btn">Verify and Continue</button>
      <a href="/owner/login" class="mini-link">Back to owner login</a>
    </form>
  </div>
<script src="/public/super-admin-shortcut.js" data-user-role="<%= user?.role || '' %>"></script>
</body>
</html>
