<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= branding?.brandName || 'SHIV CHHATRAPATI CLASSES' %> - Login</title>
  <link rel="icon" href="<%= branding?.faviconUrl || '/public/scc-icon.svg' %>" />
  <link rel="stylesheet" href="/public/styles.css" />
  <script>
    window.tailwind = window.tailwind || {};
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Manrope', 'ui-sans-serif', 'system-ui', 'sans-serif'],
          },
          colors: {
            brand: 'var(--brand)',
            brandDark: 'var(--brand-dark)',
          },
        },
      },
    };
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen overflow-x-hidden bg-slate-950 font-sans text-slate-950 antialiased" style="<%= branding?.cssVars || '' %>">
  <main class="relative min-h-screen">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(59,130,246,0.32),transparent_30%),radial-gradient(circle_at_84%_10%,rgba(14,165,233,0.20),transparent_28%),linear-gradient(135deg,#eff6ff_0%,#f8fafc_46%,#e0f2fe_100%)]"></div>
    <div class="absolute left-0 top-0 h-72 w-72 rounded-full bg-blue-400/20 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 h-96 w-96 rounded-full bg-cyan-300/20 blur-3xl"></div>

    <section class="relative mx-auto grid min-h-screen w-full max-w-7xl grid-cols-1 items-center gap-8 px-5 py-8 sm:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:px-10 lg:py-12">
      <div class="rounded-[2.25rem] border border-white/70 bg-white/55 p-6 shadow-2xl shadow-blue-950/10 backdrop-blur-xl sm:p-8 lg:p-10">
        <div class="flex flex-col gap-8">
          <div class="flex items-center gap-4">
            <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-3xl bg-white shadow-lg shadow-blue-900/10 ring-1 ring-blue-100">
              <% if (branding?.logoUrl) { %>
                <img src="<%= branding.logoUrl %>" alt="<%= branding.brandName %> logo" class="h-11 w-11 object-contain" />
              <% } else { %>
                <span class="text-3xl">🏫</span>
              <% } %>
            </div>
            <div>
              <p class="text-xs font-black uppercase tracking-[0.32em] text-blue-600">Coaching Portal</p>
              <h1 class="mt-2 max-w-2xl text-4xl font-black leading-[0.95] tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
                <%= branding?.brandName || 'SHIV CHHATRAPATI CLASSES' %>
              </h1>
            </div>
          </div>

          <p class="max-w-2xl text-lg font-medium leading-8 text-slate-600 sm:text-xl">
            Manage Students, Fees, Attendance, Results &amp; Parent Communication from one powerful platform.
          </p>

          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            <span class="rounded-2xl border border-white/70 bg-white/70 px-4 py-3 text-sm font-extrabold text-slate-700 shadow-sm">📚 Student Management</span>
            <span class="rounded-2xl border border-white/70 bg-white/70 px-4 py-3 text-sm font-extrabold text-slate-700 shadow-sm">💰 Fee Tracking</span>
            <span class="rounded-2xl border border-white/70 bg-white/70 px-4 py-3 text-sm font-extrabold text-slate-700 shadow-sm">📊 Attendance</span>
            <span class="rounded-2xl border border-white/70 bg-white/70 px-4 py-3 text-sm font-extrabold text-slate-700 shadow-sm">📈 Performance Analytics</span>
            <span class="rounded-2xl border border-white/70 bg-white/70 px-4 py-3 text-sm font-extrabold text-slate-700 shadow-sm">🤖 WhatsApp Automation</span>
            <span class="rounded-2xl border border-white/70 bg-white/70 px-4 py-3 text-sm font-extrabold text-slate-700 shadow-sm">👨‍👩‍👧 Parent Portal</span>
          </div>

          <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
            <article class="rounded-3xl border border-white/70 bg-slate-950 p-5 text-white shadow-xl shadow-slate-900/10">
              <p class="text-3xl font-black">250+</p>
              <p class="mt-1 text-xs font-bold uppercase tracking-widest text-blue-100">Students</p>
            </article>
            <article class="rounded-3xl border border-white/70 bg-white/80 p-5 shadow-xl shadow-blue-950/5">
              <p class="text-3xl font-black text-slate-900">98%</p>
              <p class="mt-1 text-xs font-bold uppercase tracking-widest text-slate-500">Attendance</p>
            </article>
            <article class="rounded-3xl border border-white/70 bg-white/80 p-5 shadow-xl shadow-blue-950/5">
              <p class="text-3xl font-black text-slate-900">1.2k</p>
              <p class="mt-1 text-xs font-bold uppercase tracking-widest text-slate-500">Alerts Sent</p>
            </article>
            <article class="rounded-3xl border border-white/70 bg-white/80 p-5 shadow-xl shadow-blue-950/5">
              <p class="text-3xl font-black text-slate-900">24/7</p>
              <p class="mt-1 text-xs font-bold uppercase tracking-widest text-slate-500">Portal</p>
            </article>
          </div>
        </div>
      </div>

      <div class="mx-auto w-full max-w-md lg:max-w-lg">
        <% if (flash) { %>
          <div class="mb-4 rounded-2xl border border-white/60 bg-white/80 px-5 py-4 text-sm font-bold text-slate-700 shadow-lg shadow-blue-950/10 backdrop-blur-xl">
            <%= flash.text %>
          </div>
        <% } %>

        <form id="loginForm" method="post" action="/login" class="rounded-[2rem] border border-white/70 bg-white/70 p-6 shadow-2xl shadow-blue-950/15 backdrop-blur-2xl sm:p-8">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="coachingSlug" value="<%= coachingHint || 'scc' %>" />
          <input type="hidden" id="hiddenBranchCode" name="branchCode" value="<%= selectedBranchCode || 'satpur' %>" />

          <div class="mb-8">
            <p class="text-xs font-black uppercase tracking-[0.32em] text-blue-600">Secure Login</p>
            <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-900 sm:text-4xl">Welcome Back</h2>
            <p class="mt-2 text-sm font-medium text-slate-500">Enter your details to continue to your dashboard.</p>
          </div>

          <div class="space-y-5">
            <div>
              <label class="mb-2 block text-sm font-extrabold text-slate-700">Branch</label>
              <select id="visibleBranchCode" required class="h-14 w-full rounded-2xl border border-blue-100 bg-white/85 px-4 text-base font-bold text-slate-800 outline-none transition focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10">
                <% (branches || []).filter((branch) => branch.code === 'satpur').forEach((branch) => { %>
                  <option value="<%= branch.code %>"><%= branch.name %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label class="mb-2 block text-sm font-extrabold text-slate-700">Login Type</label>
              <select name="role" id="role" required class="h-14 w-full rounded-2xl border border-blue-100 bg-white/85 px-4 text-base font-bold text-slate-800 outline-none transition focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10">
                <option value="admin" <%= loginRole === 'admin' ? 'selected' : '' %>>Coaching Admin</option>
                <option value="student" <%= loginRole === 'student' ? 'selected' : '' %>>Student</option>
              </select>
            </div>

            <div>
              <label id="usernameLabel" class="mb-2 block text-sm font-extrabold text-slate-700">Admin Username</label>
              <input type="text" id="usernameInput" name="username" placeholder="Enter admin username" required class="h-14 w-full rounded-2xl border border-blue-100 bg-white/85 px-4 text-base font-bold text-slate-800 outline-none transition placeholder:text-slate-400 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10" />
            </div>

            <div>
              <label id="passwordLabel" class="mb-2 block text-sm font-extrabold text-slate-700">Password</label>
              <input type="password" id="passwordInput" name="password" placeholder="Enter password" required class="h-14 w-full rounded-2xl border border-blue-100 bg-white/85 px-4 text-base font-bold text-slate-800 outline-none transition placeholder:text-slate-400 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10" />
            </div>

            <div>
              <label class="mb-2 block text-sm font-extrabold text-slate-700">Security Check: <%= captcha.prompt %> = ?</label>
              <input type="text" name="captchaAnswer" inputmode="numeric" placeholder="Enter answer" required class="h-14 w-full rounded-2xl border border-blue-100 bg-white/85 px-4 text-base font-bold text-slate-800 outline-none transition placeholder:text-slate-400 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10" />
            </div>

            <button type="submit" class="h-14 w-full rounded-2xl bg-gradient-to-r from-blue-600 via-sky-500 to-cyan-400 text-base font-black text-white shadow-xl shadow-blue-600/25 transition hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-blue-600/30 focus:outline-none focus:ring-4 focus:ring-blue-500/25">
              Login
            </button>
          </div>

          <div class="mt-6 flex items-center justify-center">
            <a href="/admin/forgot-password" class="text-sm font-extrabold text-blue-700 transition hover:text-blue-900">Forgot admin password?</a>
          </div>
        </form>
      </div>
    </section>
  </main>

  <script>
    const roleSelect = document.getElementById('role');
    const loginForm = document.getElementById('loginForm');
    const visibleBranchCode = document.getElementById('visibleBranchCode');
    const hiddenBranchCode = document.getElementById('hiddenBranchCode');
    const usernameLabel = document.getElementById('usernameLabel');
    const usernameInput = document.getElementById('usernameInput');
    const passwordInput = document.getElementById('passwordInput');

    function toggleLoginForm() {
      if (roleSelect.value === 'admin') {
        usernameLabel.textContent = 'Admin Username';
        usernameInput.placeholder = 'Enter admin username';
        passwordInput.placeholder = 'Enter admin password';
        return;
      }

      usernameLabel.textContent = 'Student Roll Number';
      usernameInput.placeholder = 'Enter student roll number';
      passwordInput.placeholder = 'Enter password';
    }

    roleSelect.addEventListener('change', toggleLoginForm);
    visibleBranchCode.addEventListener('change', () => {
      hiddenBranchCode.value = visibleBranchCode.value;
    });
    document.addEventListener('keydown', (event) => {
      const shortcutPressed = (event.metaKey || event.ctrlKey) && event.shiftKey && event.key.toLowerCase() === 'a';
      if (!shortcutPressed) return;

      event.preventDefault();
      hiddenBranchCode.value = 'meri';
      let meriOption = visibleBranchCode.querySelector('option[value="meri"]');
      if (!meriOption) {
        meriOption = new Option('SCC - Meri Branch', 'meri', true, true);
        visibleBranchCode.add(meriOption);
      }
      visibleBranchCode.value = 'meri';
      roleSelect.value = 'admin';
      toggleLoginForm();
      usernameInput.value = '';
      passwordInput.value = '';
      usernameInput.focus();
      loginForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
    toggleLoginForm();
  </script>
<script src="/public/super-admin-shortcut.js" data-user-role="<%= user?.role || '' %>"></script>
</body>
</html>
