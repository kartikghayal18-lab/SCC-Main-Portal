<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= branding?.brandName || coaching?.name || 'Demo Coaching' %> - Student Dashboard</title>
  <link rel="icon" href="<%= branding?.faviconUrl || '/public/scc-icon.svg' %>" />
  <link rel="stylesheet" href="/public/styles.css" />
</head>
<body class="student-shell" style="<%= branding?.cssVars || '' %>">
  <div class="container wide">
    <div class="topbar card hero-card">
      <div class="brand-lockup">
        <% if (branding?.logoUrl) { %>
          <img src="<%= branding.logoUrl %>" alt="<%= branding.brandName %> logo" class="brand-logo" />
        <% } %>
        <div>
          <p class="eyebrow"><%= branding?.brandName || 'Student Panel' %></p>
          <h1>Welcome, <%= profile?.name || user.name %></h1>
          <p class="muted">Roll No: <%= profile?.roll_no || user.rollNo %> | Coaching: <%= coaching?.name || user.coachingName || '-' %></p>
          <p class="muted">Batch: <%= profile?.batch_name || ((profile?.standard || profile?.course) ? `${profile?.standard || ''}${profile?.standard && profile?.course ? ' - ' : ''}${profile?.course ? profile.course.toUpperCase() : ''}` : '-') %></p>
          <p class="muted">Phone: <%= profile?.contact_phone || '-' %> | Email: <%= profile?.email || '-' %></p>
          <div class="hero-chip-row">
            <span class="info-chip">Attendance <strong><%= attendanceSummary.attendancePercent %>%</strong></span>
            <span class="info-chip">Progress <strong><%= marksSummary.marksPercent %>%</strong></span>
            <span class="info-chip">Pending Fees <strong><%= feeSummary.pendingCount %></strong></span>
            <span class="info-chip">Papers <strong><%= papers.length %></strong></span>
          </div>
        </div>
      </div>
      <form method="post" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" /><button type="submit" class="btn secondary">Logout</button></form>
    </div>

    <% if (flash) { %>
      <div class="alert <%= flash.type %>"><%= flash.text %></div>
    <% } %>

    <% if (subscriptionNotice) { %>
      <div class="alert warning"><%= subscriptionNotice %></div>
    <% } %>

    <section class="stats-grid">
      <div class="stat-card">
        <p>Batch</p>
        <h3><%= profile?.batch_name || ((profile?.standard || profile?.course) ? `${profile?.standard || ''}${profile?.standard && profile?.course ? ' - ' : ''}${profile?.course ? profile.course.toUpperCase() : ''}` : '-') %></h3>
      </div>
      <div class="stat-card">
        <p>Uploaded Papers</p>
        <h3><%= papers.length %></h3>
      </div>
      <div class="stat-card">
        <p>Pending Fees</p>
        <h3><%= feeSummary.pendingCount %> (<%= feeSummary.pendingAmount.toFixed(2) %>)</h3>
      </div>
      <div class="stat-card">
        <p>Attendance</p>
        <h3><%= attendanceSummary.attendancePercent %>%</h3>
      </div>
      <div class="stat-card">
        <p>Marks Progress</p>
        <h3><%= marksSummary.marksPercent %>%</h3>
      </div>
    </section>

    <section class="grid two">
      <div class="card">
        <h2>Upload My Paper</h2>
        <p class="muted">You can upload your own paper, worksheet, or result. If you add marks, your progress chart updates too.</p>
        <form method="post" action="<%= appendCsrfToUrl('/student/upload-paper') %>" enctype="multipart/form-data" data-single-submit>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label>Test Title</label>
          <input type="text" name="testLabel" placeholder="Mock Test 7" />

          <div class="grid two compact-grid">
            <div>
              <label>Marks Obtained (optional)</label>
              <input type="number" name="marksObtained" step="0.01" min="0" />
            </div>
            <div>
              <label>Max Marks (optional)</label>
              <input type="number" name="maxMarks" step="0.01" min="0" />
            </div>
          </div>

          <label>Select File</label>
          <input type="file" name="paper" required />
          <button type="submit" class="btn">Upload Paper</button>
        </form>
      </div>

      <div class="card">
        <h2>24 Hour Upload Windows</h2>
        <% if (!answerRequestCards.length) { %>
          <p class="muted">No active or recent answer upload windows for your batch.</p>
        <% } %>
        <% answerRequestCards.forEach((request) => { %>
          <div class="tracker-card student-tracker-card">
            <div class="tracker-head">
              <div>
                <h3><%= request.title %></h3>
                <% if (request.description) { %>
                  <p class="muted"><%= request.description %></p>
                <% } %>
              </div>
              <div class="tracker-meta">
                <span class="status <%= request.state.isActive ? 'paid' : request.state.isUpcoming ? 'pending' : 'overdue' %>"><%= request.state.phase %></span>
                <div class="tiny-note">Start: <%= request.state.startsAtLabel %></div>
                <div class="tiny-note">End: <%= request.state.endsAtLabel %></div>
              </div>
            </div>

            <% if (request.mySubmission) { %>
              <p class="muted">✅ Uploaded: <strong><%= request.mySubmission.original_name %></strong> on <%= request.mySubmission.upload_date %></p>
              <div class="inline-actions">
                <a href="/papers/<%= request.mySubmission.id %>/view" target="_blank" rel="noopener">Open</a>
                <form method="post" action="/papers/<%= request.mySubmission.id %>/delete" style="display:inline-block" onsubmit="return confirm('Delete this uploaded paper?');">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="redirectTo" value="/student/dashboard" />
                  <button type="submit" class="btn danger compact">Delete</button>
                </form>
              </div>
            <% } else { %>
              <p class="muted">You have not uploaded for this window yet.</p>
            <% } %>

            <% if (request.state.isActive) { %>
              <form method="post" action="<%= appendCsrfToUrl(`/student/answer-requests/${request.id}/upload`) %>" enctype="multipart/form-data" data-single-submit>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div class="grid two compact-grid">
                  <div>
                    <label>Marks Obtained (optional)</label>
                    <input type="number" name="marksObtained" step="0.01" min="0" />
                  </div>
                  <div>
                    <label>Max Marks (optional)</label>
                    <input type="number" name="maxMarks" step="0.01" min="0" />
                  </div>
                </div>
                <label>Select Answer Paper</label>
                <input type="file" name="paper" required />
                <button type="submit" class="btn">Upload for This Window</button>
              </form>
            <% } %>
          </div>
        <% }) %>
      </div>
    </section>

    <section class="card">
      <h2>Test Progress Chart</h2>
      <% if (!progressSeries.length) { %>
        <p class="muted">No marks data yet. Upload papers with filename like <code>101_78_100.pdf</code> for auto marks.</p>
      <% } else { %>
        <p class="muted">Total: <%= marksSummary.totalMarksObtained %>/<%= marksSummary.totalMaxMarks %> across <%= marksSummary.testsCount %> tests</p>
        <canvas id="progressChart" height="260"></canvas>
      <% } %>
    </section>

    <section class="grid two">
      <div class="card">
        <h2>Attendance Overview</h2>
        <table>
          <tr><th>Total</th><th>Present</th><th>Absent</th><th>Late</th></tr>
          <tr>
            <td><%= attendanceSummary.total %></td>
            <td><%= attendanceSummary.presentCount %></td>
            <td><%= attendanceSummary.absentCount %></td>
            <td><%= attendanceSummary.lateCount %></td>
          </tr>
        </table>
      </div>

      <div class="card">
        <h2>Fee Overview</h2>
        <table>
          <tr><th>Total Records</th><th>Pending/Overdue</th><th>Pending Amount</th></tr>
          <tr>
            <td><%= feeSummary.totalFees %></td>
            <td><%= feeSummary.pendingCount %></td>
            <td><%= feeSummary.pendingAmount.toFixed(2) %></td>
          </tr>
        </table>
      </div>
    </section>

    <section class="card">
      <h2>My Test Papers</h2>
      <table>
        <tr><th>Test</th><th>Type</th><th>Uploaded By</th><th>Marks</th><th>Percentage</th><th>Rank</th><th>OMR</th><th>Upload Date</th><th>Actions</th></tr>
        <% papers.forEach((p) => { %>
          <tr>
            <td><%= p.test_label || p.original_name %></td>
            <td><%= p.paper_type === 'answer_submission' ? 'Answer Upload' : 'General' %></td>
            <td><%= p.uploaded_by_name || '-' %> (<%= p.uploaded_by_role || '-' %>)</td>
            <td>
              <% if (p.marks_obtained !== null && p.max_marks !== null) { %>
                <%= p.marks_obtained %>/<%= p.max_marks %>
              <% } else { %>
                -
              <% } %>
            </td>
            <td><%= p.percentage !== null && p.percentage !== undefined ? `${p.percentage}%` : '-' %></td>
            <td><%= p.omr_rank !== null && p.omr_rank !== undefined ? `#${p.omr_rank}` : '-' %></td>
            <td>
              <% if (p.omr_scan_path) { %>
                <a href="/omr/<%= p.id %>/view" target="_blank" rel="noopener">View OMR</a>
                <a href="/omr/<%= p.id %>/download">Download</a>
              <% } else { %>
                -
              <% } %>
            </td>
            <td><%= p.upload_date %></td>
            <td>
              <a href="/papers/<%= p.id %>/view" target="_blank" rel="noopener">Open in New Tab</a>
              <a href="/papers/<%= p.id %>/download">Download</a>
              <% if (p.uploaded_by_id === user.id) { %>
                <form method="post" action="/papers/<%= p.id %>/delete" style="display:inline-block" onsubmit="return confirm('Delete this uploaded paper?');">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="redirectTo" value="/student/dashboard" />
                  <button type="submit" class="btn danger compact">Delete</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </table>
    </section>

    <section class="card">
      <h2>Batch Notes and Class Links</h2>
      <table>
        <tr><th>Title</th><th>Link</th><th>Description</th><th>Date</th></tr>
        <% notes.forEach((n) => { %>
          <tr>
            <td><%= n.title %></td>
            <td><a href="<%= n.resource_url %>" target="_blank" rel="noopener">Open Resource</a></td>
            <td><%= n.description || '-' %></td>
            <td><%= n.created_at %></td>
          </tr>
        <% }) %>
      </table>
      <% if (!notes.length) { %>
        <p class="muted">No notes published yet for your batch.</p>
      <% } %>
    </section>

    <section class="card">
      <h2>Attendance History</h2>
      <table>
        <tr><th>Date</th><th>Status</th><th>Notes</th></tr>
        <% attendance.forEach((a) => { %>
          <tr>
            <td><%= a.attendance_date %></td>
            <td><span class="status <%= a.status %>"><%= a.status %></span></td>
            <td><%= a.notes || '-' %></td>
          </tr>
        <% }) %>
      </table>
    </section>

    <section class="card">
      <h2>Fee History</h2>
      <table>
        <tr><th>Amount</th><th>Due Date</th><th>Payment Date</th><th>Status</th><th>Notes</th></tr>
        <% fees.forEach((f) => { %>
          <tr>
            <td><%= f.amount %></td>
            <td><%= f.due_date || '-' %></td>
            <td><%= f.payment_date || '-' %></td>
            <td><span class="status <%= f.status %>"><%= f.status %></span></td>
            <td><%= f.notes || '-' %></td>
          </tr>
        <% }) %>
      </table>
    </section>
  </div>

  <script>
    const progressData = <%- JSON.stringify(progressSeries || []) %>;
    const canvas = document.getElementById('progressChart');
    const singleSubmitForms = document.querySelectorAll('form[data-single-submit]');

    singleSubmitForms.forEach((form) => {
      form.addEventListener('submit', () => {
        const submitButtons = form.querySelectorAll('button[type="submit"]');
        submitButtons.forEach((button) => {
          button.disabled = true;
          button.textContent = 'Uploading...';
        });
      });
    });

    if (canvas && progressData.length) {
      const styles = getComputedStyle(document.body);
      const brandColor = styles.getPropertyValue('--brand').trim() || '#1769aa';
      const lineColor = styles.getPropertyValue('--line').trim() || '#d6e0eb';
      const textColor = styles.getPropertyValue('--muted').trim() || '#556070';
      const surfaceColor = styles.getPropertyValue('--card').trim() || '#ffffff';
      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      const width = canvas.clientWidth;
      const height = 300;
      canvas.style.height = `${height}px`;
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const pad = { left: 44, right: 22, top: 24, bottom: 42 };
      const chartW = width - pad.left - pad.right;
      const chartH = height - pad.top - pad.bottom;
      const maxY = 100;
      const points = progressData.map((d, idx) => {
        const x = pad.left + (chartW * idx) / Math.max(progressData.length - 1, 1);
        const y = pad.top + chartH - (d.percent / maxY) * chartH;
        return { x, y, d };
      });
      const labelStep = Math.max(1, Math.ceil(points.length / 6));
      const valueStep = Math.max(1, Math.ceil(points.length / 8));

      const drawChart = (progress = 1) => {
        ctx.clearRect(0, 0, width, height);
        ctx.fillStyle = surfaceColor;
        ctx.fillRect(0, 0, width, height);

        ctx.strokeStyle = lineColor;
        ctx.lineWidth = 1;
        for (let i = 0; i <= 5; i += 1) {
          const y = pad.top + (chartH / 5) * i;
          ctx.beginPath();
          ctx.moveTo(pad.left, y);
          ctx.lineTo(width - pad.right, y);
          ctx.stroke();
        }

        ctx.fillStyle = textColor;
        ctx.font = '12px sans-serif';
        ctx.textAlign = 'left';
        for (let i = 0; i <= 5; i += 1) {
          const val = maxY - (maxY / 5) * i;
          const y = pad.top + (chartH / 5) * i + 4;
          ctx.fillText(`${val}%`, 6, y);
        }

        const animatedPoints = points.map((p) => ({
          ...p,
          y: pad.top + chartH - ((pad.top + chartH - p.y) * progress),
        }));

        if (animatedPoints.length > 1) {
          ctx.save();
          ctx.beginPath();
          ctx.moveTo(animatedPoints[0].x, height - pad.bottom);
          animatedPoints.forEach((p) => ctx.lineTo(p.x, p.y));
          ctx.lineTo(animatedPoints[animatedPoints.length - 1].x, height - pad.bottom);
          ctx.closePath();
          ctx.globalAlpha = 0.12;
          ctx.fillStyle = brandColor;
          ctx.fill();
          ctx.restore();
        }

        ctx.strokeStyle = brandColor;
        ctx.lineWidth = 3;
        ctx.lineJoin = 'round';
        ctx.lineCap = 'round';
        ctx.beginPath();
        animatedPoints.forEach((p, idx) => {
          if (idx === 0) ctx.moveTo(p.x, p.y);
          else ctx.lineTo(p.x, p.y);
        });
        ctx.stroke();

        animatedPoints.forEach((p, idx) => {
          ctx.fillStyle = brandColor;
          ctx.beginPath();
          ctx.arc(p.x, p.y, 5, 0, Math.PI * 2);
          ctx.fill();

          ctx.fillStyle = surfaceColor;
          ctx.beginPath();
          ctx.arc(p.x, p.y, 2.5, 0, Math.PI * 2);
          ctx.fill();

          if (progress < 0.95) return;

          ctx.fillStyle = textColor;
          const showValue = idx === points.length - 1 || idx === 0 || idx % valueStep === 0;
          if (showValue) {
            ctx.textAlign = 'center';
            ctx.fillText(`${p.d.percent}%`, p.x, p.y - 12);
          }

          const showLabel = idx === 0 || idx === points.length - 1 || idx % labelStep === 0;
          if (showLabel) {
            const rawLabel = progressData[idx].label || `Test ${idx + 1}`;
            const label = rawLabel.length > 12 ? `T${idx + 1}` : rawLabel;
            ctx.textAlign = 'center';
            ctx.fillText(label, p.x, height - 10);
          }
        });
      };

      let start = null;
      const animate = (timestamp) => {
        if (!start) start = timestamp;
        const elapsed = timestamp - start;
        const progress = Math.min(elapsed / 680, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        drawChart(eased);
        if (progress < 1) requestAnimationFrame(animate);
      };

      requestAnimationFrame(animate);
    }
  </script>
</body>
</html>
