  "description": "Coaching classes management system with admin/student login, paper assignment, attendance, and fees",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node src/app.js",
    "migrate:papers:cloud": "node scripts/migrate-papers-to-cloud.js",
    "check:cloud": "node scripts/check-cloud-storage.js"
  },
  "keywords": [
    "coaching",
    "school",
    "attendance",
    "fees",
    "papers"
  ],
  "author": "",
