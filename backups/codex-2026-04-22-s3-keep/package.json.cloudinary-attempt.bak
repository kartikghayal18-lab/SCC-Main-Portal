    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "sqlite3": "^5.1.7",
    "twilio": "^5.13.1",
    "ws": "^8.20.0"
  }
}
