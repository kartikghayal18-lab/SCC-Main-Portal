# Legacy verbose example. For new client copies, start from .env.template.
# App
NODE_ENV=development
PORT=3000
SESSION_SECRET=change-this-session-secret

# Admin credentials (set your own before production if your seed logic uses them)
ADMIN_USERNAME=kartiiik001
ADMIN_PASSWORD=Ga7BU8cZ
ADMIN_FORCE_RESET=false
MERI_ADMIN_USERNAME=scc-meri-admin
MERI_ADMIN_PASSWORD=
MERI_ADMIN_NAME=Meri Branch Admin
MERI_ADMIN_EMAIL=
MERI_ADMIN_PHONE=

# Approved Meta template used for first-contact student registration messages.
WHATSAPP_REGISTRATION_TEMPLATE_NAME=admission_confirmed
WHATSAPP_REGISTRATION_TEMPLATE_LANGUAGE=en

# Used for owner 2FA if the owner account does not have email/phone saved in DB.
OWNER_2FA_EMAIL=
OWNER_2FA_PHONE=

########################################
# DATABASE (Neon/PostgreSQL)
########################################

DATABASE_URL=postgresql://YOUR_NEON_USERNAME:YOUR_NEON_PASSWORD@YOUR_NEON_HOST/YOUR_NEON_DATABASE?sslmode=require

########################################
# UPLOADS
########################################

# Vercel requires s3. Render/local Node can use local only for development.
FILE_STORAGE_MODE=s3
UPLOAD_FILE_SIZE_LIMIT_BYTES=

# S3-compatible storage config
# AWS S3 example endpoint: https://s3.ap-south-1.amazonaws.com
# Cloudflare R2 example endpoint: https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Optional: if you use a public CDN/base URL for files
S3_PUBLIC_BASE_URL=

# Signed URL validity seconds
S3_SIGNED_URL_TTL_SECONDS=600

########################################
# OTP DELIVERY
########################################

# Email OTP via SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FAMILY=4
SMTP_CONNECTION_TIMEOUT=20000
SMTP_GREETING_TIMEOUT=15000
SMTP_SOCKET_TIMEOUT=30000
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
MAIL_DEBUG_SECRET=

# Email OTP via Resend
RESEND_API_KEY=
RESEND_FROM=

# SMS OTP via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
