# Copy this file to .env for each new client deployment.
# Deployment-specific environment configuration lives here.

PORT=3000
DATABASE_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET=

RESEND_API_KEY=
RESEND_FROM=
JWT_SECRET=

# App compatibility settings
SESSION_SECRET=
FILE_STORAGE_MODE=s3
LOCAL_PAPER_DIR=./uploads
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
S3_SIGNED_URL_TTL_SECONDS=600

# Owner recovery / admin mail helpers
OWNER_2FA_EMAIL=
OWNER_2FA_PHONE=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FAMILY=4
SMTP_CONNECTION_TIMEOUT=20000
SMTP_GREETING_TIMEOUT=15000
SMTP_SOCKET_TIMEOUT=30000
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
MAIL_DEBUG_SECRET=

# WhatsApp approved template fallback for paper/result delivery
WHATSAPP_PAPER_TEMPLATE_NAME=paper_result_notification
WHATSAPP_TEMPLATE_LANGUAGE=en
